{
  "version": 2,
  "builds": [
    { "src": "api/ploomes.js", "use": "@vercel/node" },
    { "src": "public/**",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ploomes", "dest": "/api/ploomes.js" },
    { "src": "/",            "dest": "/public/index.html" },
    { "src": "/(.*)",        "dest": "/public/$1" }
  ]
}
